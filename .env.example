# Setoku single-box deployment — copy to .env and fill in.
# Everything here stays on the box; nothing is baked into images.

# ── identity ────────────────────────────────────────────────────────────────
# Public hostname (DNS A record → this box). "localhost" = local dev.
SETOKU_DOMAIN=setoku.example.com

# ── profiles ────────────────────────────────────────────────────────────────
# core (caddy+server+postgres) always runs. Add the lake and ingest pipeline:
COMPOSE_PROFILES=lake,ingest

# ── secrets (generate each: openssl rand -hex 24) ───────────────────────────
# Per-user MCP tokens: "token=identity,token=identity"
SETOKU_TOKENS=CHANGE-ME=you@example.com
# Bearer token for POSTs to /ingest/* (Vercel/Render drains, app events)
SETOKU_INGEST_TOKEN=CHANGE-ME
POSTGRES_PASSWORD=CHANGE-ME
CLICKHOUSE_USER=setoku
CLICKHOUSE_PASSWORD=CHANGE-ME

# ── gateway ─────────────────────────────────────────────────────────────────
# Business database for run_query (postgres dialect), if any. Read-only role!
# See deploy/readonly-role.sql.
SETOKU_DATABASE_URL=
# Dependency pings aggregated by /healthz. Match enabled profiles.
SETOKU_HEALTHZ_PING=clickhouse=http://clickhouse:8123/ping,vector=http://vector:8686/health

# ── clickhouse sizing ───────────────────────────────────────────────────────
# small = 4–8 GB boxes (Hetzner CX32) · roomy = 24 GB prototype (Oracle A1)
SETOKU_CH_PRESET=small

# ── backups (I4 — bucket on a DIFFERENT provider than the box) ──────────────
# S3-compatible: Backblaze B2, Cloudflare R2, Hetzner Object Storage, …
SETOKU_BACKUP_S3_ENDPOINT=
SETOKU_BACKUP_S3_BUCKET=
SETOKU_BACKUP_S3_ACCESS_KEY=
SETOKU_BACKUP_S3_SECRET_KEY=
SETOKU_BACKUP_S3_PROVIDER=Other

# ── monitoring ──────────────────────────────────────────────────────────────
# Webhook hit by deploy/monitor/alert.sh on unhealthy /healthz or disk ≥75%
SETOKU_ALERT_WEBHOOK=

# ── local dev only ──────────────────────────────────────────────────────────
# Remap the public ports if 80/443 are taken on your workstation.
#SETOKU_EDGE_HTTP_PORT=8080
#SETOKU_EDGE_HTTPS_PORT=8443
