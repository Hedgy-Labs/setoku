{
  "name": "setoku-dev",
  "private": true,
  "description": "Dev/test harness for the Setoku plugin (the installable plugin lives in ./plugin)",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "test": "bun test test/ ingest/",
    "test:e2e": "bun test e2e/",
    "eval:knowledge": "bun plugin/gateway/quality-cli.ts",
    "eval:value": "bun demo/eval/value.ts",
    "eval:retrieval": "bun demo/eval/retrieval.ts",
    "eval:embed": "bun demo/eval/embed-retrieval.ts",
    "eval:friction": "bun plugin/gateway/friction-cli.ts",
    "knowledge-lint": "bun plugin/gateway/knowledge-lint.ts",
    "setup:hooks": "git config core.hooksPath scripts/hooks",
    "typecheck": "tsc --noEmit",
    "build:admin-css": "tailwindcss -i plugin/gateway/web/input.css -o plugin/gateway/web/app.css --minify",
    "build:admin-js": "bun plugin/gateway/web/build-admin.ts",
    "build:admin": "bun run build:admin-css && bun run build:admin-js",
    "dev:admin": "bun plugin/gateway/web/dev.ts",
    "deploy": "bash scripts/deploy.sh",
    "deploy:demo": "bash scripts/deploy-demo.sh",
    "deploy:site": "bash scripts/deploy-site.sh",
    "test:demo-e2e": "bun run demo/e2e/run.ts",
    "test:knowledge-lint": "bun run demo/e2e/knowledge-lint.ts demo/bulldogs"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "clsx": "^2.1.1",
    "pg": "^8.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@types/bun": "^1.2.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "fastembed": "^2.1.0",
    "playwright-core": "^1.61.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.0"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "onnxruntime-node",
    "protobufjs"
  ]
}
