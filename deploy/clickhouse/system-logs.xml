<!-- Setoku ClickHouse system-log retention.

     ClickHouse's own telemetry tables (system.query_log, trace_log, metric_log,
     asynchronous_metric_log, …) are UNBOUNDED by default and, on a busy box,
     outgrow the actual lake data many times over (observed ~160 MB/day of
     telemetry vs ~14 MB/day of real ingest). These tables are rebuildable
     server diagnostics, NOT user data (I4) — so cap them with a rolling TTL.

     14 days is plenty for post-incident debugging. On a fresh box the tables
     grow from empty, so the TTL applies incrementally (no expensive rewrite).
     Mounted at /etc/clickhouse-server/config.d/ ; applies on (re)start. -->
<clickhouse>
    <query_log><ttl>event_date + INTERVAL 14 DAY DELETE</ttl></query_log>
    <query_thread_log><ttl>event_date + INTERVAL 14 DAY DELETE</ttl></query_thread_log>
    <trace_log><ttl>event_date + INTERVAL 14 DAY DELETE</ttl></trace_log>
    <text_log><ttl>event_date + INTERVAL 14 DAY DELETE</ttl></text_log>
    <metric_log><ttl>event_date + INTERVAL 14 DAY DELETE</ttl></metric_log>
    <asynchronous_metric_log><ttl>event_date + INTERVAL 14 DAY DELETE</ttl></asynchronous_metric_log>
    <processors_profile_log><ttl>event_date + INTERVAL 14 DAY DELETE</ttl></processors_profile_log>
    <part_log><ttl>event_date + INTERVAL 14 DAY DELETE</ttl></part_log>
</clickhouse>
