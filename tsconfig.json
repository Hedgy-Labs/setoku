{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["bun", "node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false
  },
  "include": [
    "plugin/gateway/**/*.ts",
    "plugin/gateway/web/app/**/*.tsx",
    "provisioner/**/*.ts",
    "test/**/*.ts",
    "e2e/**/*.ts"
  ]
}
