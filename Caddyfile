# Setoku edge — the only public-facing container (I1).
# Auto-HTTPS for SETOKU_DOMAIN; `localhost` uses Caddy's internal CA (dev).
# SETOKU_ALT_DOMAIN is an optional second hostname served by the same site
# (each gets its own Let's Encrypt cert) — used to keep an old domain alive
# while migrating to a new one. Empty by default (single-domain deploys).

{$SETOKU_DOMAIN:localhost} {$SETOKU_ALT_DOMAIN} {
	encode gzip

	# Vercel log-drain endpoint verification (I7): when you create a drain,
	# Vercel probes this URL and requires the response to echo an
	# `x-vercel-verify` header with the team's value. Set SETOKU_VERCEL_VERIFY
	# in .env to that value (Vercel returns it in the create-drain error/UI).
	# Harmless when empty for non-Vercel deploys. Applies to all ingest
	# responses, including the 401, so verification passes before auth is set.
	header /ingest/* x-vercel-verify "{$SETOKU_VERCEL_VERIFY}"

	# Render log streams (HTTPS): Render's "Token" field delivery mechanism is
	# undocumented, so we authenticate via the token in the URL PATH instead of
	# a header. Set the Render Log Endpoint to:
	#   https://<domain>/ingest/render/<SETOKU_INGEST_TOKEN>
	# The token segment is verified, then stripped so Vector routes it as
	# /ingest/render. (Must precede the generic /ingest/* handle below.)
	handle /ingest/render/* {
		@ok path /ingest/render/{$SETOKU_INGEST_TOKEN} /ingest/render/{$SETOKU_INGEST_TOKEN}/*
		handle @ok {
			rewrite * /ingest/render
			reverse_proxy vector:8080
		}
		handle {
			respond "unauthorized" 401
		}
	}

	# Mercury webhooks (OPTIONAL): Mercury POSTs transaction-change events to a URL
	# you register in its dashboard. Like Render, we authenticate via a token in
	# the URL PATH. Register the webhook URL as:
	#   https://<domain>/ingest/mercury/<SETOKU_INGEST_TOKEN>
	# The token segment is verified, then stripped so Vector routes it as
	# /ingest/mercury → mercury_events. (Must precede the generic /ingest/* handle.)
	# Note: the poller talks to Vector directly on the internal network, so its
	# /ingest/mercury/accounts and /transactions paths never traverse Caddy.
	# TODO hardening: also verify Mercury's HMAC signature on the raw body.
	handle /ingest/mercury/* {
		@ok path /ingest/mercury/{$SETOKU_INGEST_TOKEN} /ingest/mercury/{$SETOKU_INGEST_TOKEN}/*
		handle @ok {
			rewrite * /ingest/mercury
			reverse_proxy vector:8080
		}
		handle {
			respond "unauthorized" 401
		}
	}

	# Ingest: bearer token checked at the edge; Vector never sees
	# unauthenticated traffic. Vercel drains send Authorization: Bearer; app
	# events POST it too. (Render uses the path-token route above.)
	handle /ingest/* {
		@authed header Authorization "Bearer {$SETOKU_INGEST_TOKEN}"
		handle @authed {
			reverse_proxy vector:8080
		}
		handle {
			respond "unauthorized" 401
		}
	}

	# MCP gateway (header bearer auth, or token-in-URL-path for the consumer
	# custom-connector dialog), the one-line installer, and health.
	handle /mcp* {
		reverse_proxy server:8787
	}
	handle /i/* {
		reverse_proxy server:8787
	}
	# web approval surface — the human accept/reject path (Phase 5.5)
	handle /admin* {
		reverse_proxy server:8787
	}
	# public reports — credential-free /p/<id> links (the server serves ONLY
	# reports an admin promoted to public; everything else 404s).
	handle /p/* {
		reverse_proxy server:8787
	}
	handle /health* {
		reverse_proxy server:8787
	}

	# The web console (React SPA) is served at the site ROOT by the gateway, so
	# the gateway is the default backend: it renders the SPA shell for its known
	# routes (/, /apps/<id>, /knowledge, /sources, /team, /audit) and returns 404
	# for anything else. The specific handles above (ingest/mcp/i/admin/p/health)
	# still win by matcher specificity.
	handle {
		reverse_proxy server:8787
	}
}

# Box-local extra site blocks (e.g. demo subdomains) live in /etc/caddy/conf.d
# (the ./caddy.d dir mounted in docker-compose). They are NOT in the repo and the
# deploy does NOT rsync them, so they survive deploys *and* container recreates —
# unlike appending to this file, which the deploy clobbers. Each *.caddy file is a
# full site block. An empty/absent dir makes this import a harmless no-op.
#
# Only the EXPLICIT hostnames named here and in conf.d get a cert and are served;
# with on-demand TLS off, any other host (e.g. a typo under a wildcard *.setoku.com
# A record) fails the TLS handshake rather than being served a wrong vhost (I1).
import /etc/caddy/conf.d/*.caddy
