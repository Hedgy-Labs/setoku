# Setoku edge — the only public-facing container (I1).
# Auto-HTTPS for SETOKU_DOMAIN; `localhost` uses Caddy's internal CA (dev).

{$SETOKU_DOMAIN:localhost} {
	encode gzip

	# Vercel log-drain endpoint verification (I7): when you create a drain,
	# Vercel probes this URL and requires the response to echo an
	# `x-vercel-verify` header with the team's value. Set SETOKU_VERCEL_VERIFY
	# in .env to that value (Vercel returns it in the create-drain error/UI).
	# Harmless when empty for non-Vercel deploys. Applies to all ingest
	# responses, including the 401, so verification passes before auth is set.
	header /ingest/* x-vercel-verify "{$SETOKU_VERCEL_VERIFY}"

	# Render log streams (HTTPS): Render's "Token" field delivery mechanism is
	# undocumented, so we authenticate via the token in the URL PATH instead of
	# a header. Set the Render Log Endpoint to:
	#   https://<domain>/ingest/render/<SETOKU_INGEST_TOKEN>
	# The token segment is verified, then stripped so Vector routes it as
	# /ingest/render. (Must precede the generic /ingest/* handle below.)
	handle /ingest/render/* {
		@ok path /ingest/render/{$SETOKU_INGEST_TOKEN} /ingest/render/{$SETOKU_INGEST_TOKEN}/*
		handle @ok {
			rewrite * /ingest/render
			reverse_proxy vector:8080
		}
		handle {
			respond "unauthorized" 401
		}
	}

	# Ingest: bearer token checked at the edge; Vector never sees
	# unauthenticated traffic. Vercel drains send Authorization: Bearer; app
	# events POST it too. (Render uses the path-token route above.)
	handle /ingest/* {
		@authed header Authorization "Bearer {$SETOKU_INGEST_TOKEN}"
		handle @authed {
			reverse_proxy vector:8080
		}
		handle {
			respond "unauthorized" 401
		}
	}

	# MCP gateway (header bearer auth, or token-in-URL-path for the consumer
	# custom-connector dialog), the one-line installer, and health.
	handle /mcp* {
		reverse_proxy server:8787
	}
	handle /i/* {
		reverse_proxy server:8787
	}
	# web approval surface — the human accept/reject path (Phase 5.5)
	handle /admin* {
		reverse_proxy server:8787
	}
	handle /health* {
		reverse_proxy server:8787
	}

	handle {
		respond "setoku" 404
	}
}
